---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import Gravatar from '../components/Gravatar.astro';
import { AUTHOR } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---
<BaseLayout title={AUTHOR.name} bodyClass="archive-template">
  <header class="main-header author-head no-cover">
    <nav class="main-nav overlay clearfix">
      <a class="back-button icon-arrow-left" href="/">Home</a>
      <a class="subscribe-button icon-feed" href="/feed.xml">{AUTHOR.name}</a>
    </nav>
  </header>

  <section class="author-profile inner">
    <figure class="author-image">
      <div class="img">
        <Gravatar size={114} />
        <span class="hidden">{AUTHOR.name}'s Picture</span>
      </div>
    </figure>
    <h1 class="author-title">{AUTHOR.name}</h1>
    <h2 class="author-bio">{AUTHOR.bio}</h2>
    <div class="author-meta">
      <span class="author-stats">
        <i class="icon-stats"></i>
        {posts.length} {posts.length === 1 ? 'post' : 'posts'}
      </span>
    </div>
  </section>

  <main id="content" class="content" role="main">
    <PostList posts={posts} />
  </main>
</BaseLayout>
