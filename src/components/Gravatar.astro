---
import { createHash } from 'node:crypto';
import { AUTHOR } from '../consts';

interface Props {
  size?: number;
  class?: string;
}

const { size = 68, class: className } = Astro.props;
const md5 = createHash('md5').update(AUTHOR.gravatarEmail.toLowerCase()).digest('hex');
const url = `https://www.gravatar.com/avatar/${md5}?size=${size}`;
---
<img src={url} alt={`${AUTHOR.name}'s Picture`} width={size} height={size} class={className} />
