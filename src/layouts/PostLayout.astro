---
import BaseLayout from './BaseLayout.astro';
import Gravatar from '../components/Gravatar.astro';
import { AUTHOR, SITE } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, subtitle, date, cover, tags } = post.data;

const coverUrl = cover ? `/images/${cover}` : null;
const dateStr = date.toLocaleDateString('en-GB', SITE.dateFormat);
const isoDate = date.toISOString().slice(0, 10);

const description = subtitle ?? SITE.description;
const articleUrl = new URL(Astro.url.pathname, Astro.site).toString();
const twitterUrl = `https://twitter.com/share?text=${encodeURIComponent(title)}&url=${encodeURIComponent(articleUrl)}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`;
---
<BaseLayout title={title} description={description} bodyClass="post-template">
  <header
    class={`main-header post-head ${coverUrl ? '' : 'no-cover'}`}
    style={coverUrl ? `background-image: url(${coverUrl})` : undefined}
  >
    <nav class={`main-nav clearfix ${coverUrl ? 'overlay' : ''}`}>
      <a class="back-button icon-arrow-left" href="/">Home</a>
      <a class="subscribe-button icon-feed" href="/feed.xml">Subscribe</a>
    </nav>
  </header>

  <main class="content" role="main">
    <article class="post">
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <section class="post-meta">
          <time class="post-date" datetime={isoDate}>{dateStr}</time>
          {tags.length > 0 && (
            <Fragment>
              {' on '}
              {tags.map((tag, i) => (
                <Fragment>
                  <a href={`/tags/${tag.toLowerCase()}/`}>{tag}</a>
                  {i < tags.length - 1 && ', '}
                </Fragment>
              ))}
            </Fragment>
          )}
        </section>
      </header>

      <section class="post-content">
        <slot />
      </section>

      <footer class="post-footer">
        <figure class="author-image">
          <a class="img" href="/author/">
            <Gravatar size={68} />
            <span class="hidden">{AUTHOR.name}'s Picture</span>
          </a>
        </figure>
        <section class="author">
          <h4><a href="/author/">{AUTHOR.name}</a></h4>
          <p>{AUTHOR.bio}</p>
        </section>

        <section class="share">
          <h4>Share this post</h4>
          <a
            class="icon-twitter"
            href={twitterUrl}
            onclick="window.open(this.href, 'twitter-share', 'width=550,height=235');return false;"
          >
            <span class="hidden">Twitter</span>
          </a>
          <a
            class="icon-facebook"
            href={facebookUrl}
            onclick="window.open(this.href, 'facebook-share','width=580,height=296');return false;"
          >
            <span class="hidden">Facebook</span>
          </a>
        </section>
      </footer>
    </article>
  </main>
</BaseLayout>
